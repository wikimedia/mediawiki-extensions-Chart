{
	"name": "Chart",
	"author": [
		"Brooke Vibber",
		"Katie Filbert",
		"Roan Kattouw"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:Chart",
	"descriptionmsg": "chart-desc",
	"license-name": "GPL-3.0-or-later",
	"type": "parserhook",
	"requires": {
		"MediaWiki": ">= 1.47.0",
		"extensions": {
			"JsonConfig": "*"
		}
	},
	"config": {
		"ChartProgressiveEnhancement": {
			"value": true,
			"description": "Loads JavaScript on client."
		},
		"ChartServiceUrl": {
			"value": null,
			"description": "URL to the chart-renderer service. If both ChartCliPath and this setting are set, this setting is used."
		},
		"ChartCliPath": {
			"value": null,
			"description": "File path to the chart-renderer CLI script. Defaults to 'path/to/extensions/Chart/chart-renderer/cli.js'. If both ChartServiceUrl and this setting are set, this setting is ignored and ChartServiceUrl is used."
		},
		"ChartTransformsEnabled": {
			"value": false,
			"description": "Enables Lua transforms of input data specified in chart definitions."
		},
		"ChartRequestSizeLimit": {
			"value": 100000,
			"description": "Maximum size of request payload in bytes when sending data to the chart-renderer service. Default is 100KB."
		},
		"ChartWizardEnabled": {
			"value": false,
			"description": "Enables the chart wizard form when creating or editing a chart definition page."
		}
	},
	"callback": "MediaWiki\\Extension\\Chart\\Hooks::onRegistration",
	"TrackingCategories": [
		"chart-render-category",
		"chart-error-category"
	],
	"AutoloadNamespaces": {
		"MediaWiki\\Extension\\Chart\\": "src/"
	},
	"TestAutoloadNamespaces": {
		"MediaWiki\\Extension\\Chart\\Tests\\": "tests/phpunit/"
	},
	"TestAutoloadClasses": {
		"MediaWiki\\Extension\\Chart\\Tests\\Integration\\ChartIntegrationTestTrait": "tests/phpunit/integration/ChartIntegrationTestTrait.php"
	},
	"ForeignResourcesDir": "lib",
	"ServiceWiringFiles": [
		"src/ServiceWiring.php"
	],
	"MessagesDirs": {
		"Chart": [
			"i18n"
		]
	},
	"APIModules": {
		"chartinfo": {
			"class": "MediaWiki\\Extension\\Chart\\ApiChartInfo",
			"services": [
				"MainWANObjectCache",
				"JsonConfig.GlobalJsonLinks"
			]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "",
		"remoteExtPath": "Chart"
	},
	"ResourceModules": {
		"ext.chart.styles": {
			"styles": [
				"resources/ext.chart/styles.less"
			]
		},
		"ext.chart.bootstrap": {
			"packageFiles": [
				"resources/ext.chart/bootstrap.js"
			],
			"dependencies": [
				"web2017-polyfills"
			]
		},
		"ext.chart.render": {
			"packageFiles": [
				"resources/ext.chart/render.js",
				"lib/echarts/echarts.common.js"
			],
			"messages": [
				"chart-render-tooltip-nodata"
			]
		},
		"ext.chart.visualEditor": {
			"scripts": [
				"resources/ext.chart.visualEditor/ve.dm.MWChartNode.js",
				"resources/ext.chart.visualEditor/ve.ce.MWChartNode.js",
				"resources/ext.chart.visualEditor/ve.ui.MWChartContextItem.js",
				"resources/ext.chart.visualEditor/ve.ui.MWChartDialog.js",
				"resources/ext.chart.visualEditor/ve.ui.MWChartDialogTool.js"
			],
			"dependencies": [
				"ext.visualEditor.mwcore",
				"ext.visualEditor.mwtransclusion"
			],
			"messages": [
				"chart-visualeditor-mwchartdialog-title",
				"chart-visualeditor-mwchartdialog-chart-label",
				"chart-visualeditor-mwchartdialog-data-label"
			]
		},
		"ext.chart.wizard": {
			"class": "MediaWiki\\ResourceLoader\\CodexModule",
			"dependencies": [
				"vue",
				"pinia",
				"mediawiki.Title"
			],
			"packageFiles": [
				"resources/ext.chart.wizard/init.js",
				"resources/ext.chart.wizard/stores/chart.js",
				"resources/ext.chart.wizard/components/ChartForm.vue",
				"resources/ext.chart.wizard/components/ChartPreview.vue",
				"resources/ext.chart.wizard/components/ChartWizard.vue",
				"resources/ext.chart.wizard/components/SourceField.vue",
				"resources/ext.chart.wizard/components/ChartConfigure.vue",
				"resources/ext.chart.wizard/components/ChartTypeField.vue",
				"resources/ext.chart.wizard/components/CategoriesField.vue",
				{
					"name": "resources/ext.chart.wizard/icons.json",
					"callback": "MediaWiki\\ResourceLoader\\CodexModule::getIcons",
					"callbackParam": [
						"cdxIconChart",
						"cdxIconChartBar",
						"cdxIconChartLine",
						"cdxIconChartPie"
					]
				}
			],
			"codexComponents": [
				"CdxButton",
				"CdxField",
				"CdxLookup",
				"CdxMessage",
				"CdxMultiselectLookup",
				"CdxSelect"
			],
			"messages": [
				"chart-error-data-source-page-not-found",
				"chart-wizard-form-configure-description",
				"chart-wizard-form-configure-label",
				"chart-wizard-form-source-description",
				"chart-wizard-form-source-label",
				"chart-wizard-form-source-placeholder",
				"chart-wizard-form-categories",
				"chart-wizard-form-categories-no-results",
				"chart-wizard-form-categories-placeholder",
				"chart-wizard-form-type-area",
				"chart-wizard-form-type-area-description",
				"chart-wizard-form-type-bar",
				"chart-wizard-form-type-bar-description",
				"chart-wizard-form-type-label",
				"chart-wizard-form-type-line",
				"chart-wizard-form-type-line-description",
				"chart-wizard-form-type-pie",
				"chart-wizard-form-type-pie-description",
				"chart-wizard-form-type-placeholder",
				"chart-wizard-preview-data-view",
				"chart-wizard-preview-error",
				"chart-wizard-preview-error-retry",
				"chart-wizard-preview-chart-view",
				"chart-wizard-preview-placeholder-description",
				"chart-wizard-preview-placeholder-title",
				"chart-wizard-publish",
				"publishchanges"
			]
		},
		"ext.chart.wizard.styles": {
			"styles": [
				"resources/ext.chart.wizard/styles.less"
			]
		}
	},
	"ExtensionMessagesFiles": {
		"ChartMagic": "Chart.i18n.magic.php",
		"ChartAlias": "Chart.i18n.alias.php"
	},
	"HookHandlers": {
		"main": {
			"class": "MediaWiki\\Extension\\Chart\\Hooks",
			"services": [
				"SpecialPageFactory",
				"MainConfig"
			]
		}
	},
	"Hooks": {
		"LinksUpdateComplete": "main",
		"ParserFirstCallInit": "main",
		"PageSaveComplete": "main",
		"SkinTemplateNavigation::Universal": "main",
		"RecentChange_save": "main",
		"ListDefinedTags": "MediaWiki\\Extension\\Chart\\Hooks::onRegisterTags",
		"ChangeTagsListActive": "MediaWiki\\Extension\\Chart\\Hooks::onRegisterTags"
	},
	"SpecialPages": {
		"ChartWizard": {
			"class": "MediaWiki\\Extension\\Chart\\SpecialChartWizard",
			"services": [
				"WikiPageFactory",
				"MainConfig",
				"Chart.Logger"
			]
		}
	},
	"attributes": {
		"VisualEditor": {
			"PluginModules": [
				"ext.chart.visualEditor"
			]
		},
		"WikiEditor": {
			"RealtimePreviewContentModels": [
				"Chart.JsonConfig"
			]
		}
	},
	"manifest_version": 2
}
